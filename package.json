{
  "name": "mentorhub-backend",
  "version": "1.0.0",
  "description": "MentorHub AI-Powered Mentorship Platform Backend",
  "main": "dist/server.js",
  "type": "module",
  "prisma": {
    "seed": "tsx src/app/utils/seed.ts"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate && tsc --project tsconfig.json",
    "start": "node dist/server.js",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:seed": "tsx src/app/utils/seed.ts"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "bcryptjs": "^2.4.3",
    "better-auth": "^1.4.18",
    "cloudinary": "^2.9.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "http-status": "^2.1.0",
    "jsonwebtoken": "^9.0.3",
    "ms": "^2.1.3",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.1",
    "pg": "^8.18.0",
    "qs": "^6.14.1",
    "socket.io": "^4.8.1",
    "uuid": "^11.0.0",
    "winston": "^3.17.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
