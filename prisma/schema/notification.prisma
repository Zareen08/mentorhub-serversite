model Notification {
  id          String           @id @default(uuid(7))
  userId      String
  userProfile UserProfile      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        NotificationType
  title       String
  message     String
  data        Json?
  isRead      Boolean          @default(false)
  createdAt   DateTime         @default(now())

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}
