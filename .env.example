# ── REQUIRED ──────────────────────────────────────────────
NODE_ENV=development
PORT=5000

# PostgreSQL — get free DB at https://neon.tech
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Better-Auth — generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=your-32-char-secret-here
BETTER_AUTH_URL=http://localhost:5000

# JWT — generate two different secrets
ACCESS_TOKEN_SECRET=your-access-token-secret
REFRESH_TOKEN_SECRET=your-refresh-token-secret
ACCESS_TOKEN_EXPIRES_IN=1d
REFRESH_TOKEN_EXPIRES_IN=30d
BETTER_AUTH_SESSION_TOKEN_EXPIRES_IN=7
BETTER_AUTH_SESSION_TOKEN_UPDATE_AGE=1

# ── RECOMMENDED ───────────────────────────────────────────
# Gemini AI — free at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

FRONTEND_URL=http://localhost:3000

# ── OPTIONAL ──────────────────────────────────────────────
# Cloudinary — https://cloudinary.com (free tier)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# SMTP Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@mentorhub.com

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Seeded admin credentials (change these!)
SUPER_ADMIN_EMAIL=admin@mentorhub.com
SUPER_ADMIN_PASSWORD=Admin123!
